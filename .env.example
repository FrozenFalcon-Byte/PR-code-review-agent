# --- Model provider (pick one) ---
# Options: openrouter | gemini | groq | ollama
MODEL_PROVIDER=openrouter

# OpenRouter — free models, no daily token limits — https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here
# Free models with tool calling support:
#   meta-llama/llama-3.3-70b-instruct:free   (best quality)
#   google/gemma-3-27b-it:free
#   mistralai/mistral-7b-instruct:free
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# Gemini — https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_google_api_key_here

# Groq — https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Ollama (fully local) — run `ollama pull llama3.2` first
OLLAMA_MODEL=llama3.2

# Cerebras (free tier: 30 RPM, 1M tokens/day, fast) — https://cloud.cerebras.ai
CEREBRAS_API_KEY=your_cerebras_api_key_here
CEREBRAS_MODEL=llama3.3-70b

# GitHub (optional — raises rate limits for repo API calls)
GITHUB_TOKEN=your_github_token_here
